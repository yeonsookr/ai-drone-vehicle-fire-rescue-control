# Bind to the Jetson network interface. A token is mandatory for non-loopback binding.
EDGE_AI_HOST=0.0.0.0
EDGE_AI_PORT=5001
EDGE_AI_API_TOKEN=replace-with-a-long-random-token
EDGE_AI_ALLOW_INSECURE_REMOTE=false

# Current Spring backend contract.
BACKEND_BASE_URL=http://192.168.0.10:8080
BACKEND_API_TOKEN=
BACKEND_TIMEOUT_SECONDS=5
BACKEND_PUBLISH_ENABLED=true
BACKEND_PUBLISH_ATTEMPTS=3

# Backend <-> Jetson control/status/AI metadata channel.
MQTT_ENABLED=true
MQTT_HOST=192.168.0.10
MQTT_PORT=1883
MQTT_CLIENT_ID=jetson-edge-ai-V-01
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false
MQTT_KEEPALIVE_SECONDS=30
MQTT_QOS=1
MQTT_STATUS_INTERVAL_SECONDS=10
MQTT_COMMAND_DEFAULT_TTL_SECONDS=30

# Jetson identity and inference model.
EDGE_VEHICLE_ID=V-01
EDGE_AI_ENGINE=ultralytics
EDGE_AI_MODEL_PATH=/opt/models/wildfire/best.pt
EDGE_AI_MODEL_VERSION=wildfire-orin-v1.0.0
EDGE_AI_DEVICE=cuda:0
EDGE_AI_IMAGE_SIZE=640
EDGE_AI_CONFIDENCE_THRESHOLD=0.25
EDGE_AI_REVIEW_THRESHOLD=0.50

# Map labels emitted by the custom model to the shared backend classes.
EDGE_AI_CLASS_MAP_JSON={"fire":"forest_fire","flame":"forest_fire","smoke":"smoke","person":"distressed_person"}

# Resource limits. The implementation always serializes GPU inference.
EDGE_AI_MAX_REQUEST_BYTES=10485760
EDGE_AI_RESULT_CACHE_SIZE=256
EDGE_AI_PUBLISH_QUEUE_SIZE=128
EDGE_AI_FRAME_QUEUE_SIZE=8
EDGE_AI_FRAME_BUFFER_SIZE=60
EDGE_AI_EVIDENCE_FRAME_COUNT=3
EDGE_AI_EVIDENCE_WINDOW_SECONDS=10
EDGE_AI_EVENT_COOLDOWN_SECONDS=30
EDGE_AI_COMMAND_CACHE_SIZE=128
